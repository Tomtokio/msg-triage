# VetTriage v0 — variabili d'ambiente.
# Copia questo file in .env e compila i valori. NON committare .env (è in .gitignore).

# Callbell — API key (richiede il piano "Chat Management Plus").
CALLBELL_API_KEY=

# Anthropic — API key per il triage.
ANTHROPIC_API_KEY=

# Telegram — token del bot (da @BotFather).
TELEGRAM_BOT_TOKEN=

# Telegram — ID numerico dell'unico utente autorizzato (whitelist).
TELEGRAM_ALLOWED_USER_ID=

# Supabase — URL del progetto e chiave di servizio.
SUPABASE_URL=
SUPABASE_KEY=

# Livello di logging (opzionale): DEBUG | INFO | WARNING | ERROR. Default: INFO.
LOG_LEVEL=INFO
